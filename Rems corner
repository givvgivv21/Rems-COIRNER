<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REMS CORNER | TERMINAL OS v4.0</title>
    <style>
        /* --- CORE SYSTEM THEME --- */
        :root {
            --primary: #00ff66;
            --primary-glow: rgba(0, 255, 102, 0.4);
            --bg-dark: #011a12;
            --bg-nav: #05070a;
            --panel: #000000;
            --danger: #ff4444;
            --text-dim: #4a8c6f;
        }

        @font-face {
            font-family: 'Terminal';
            src: local('Consolas'), local('Courier New'), monospace;
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            background: var(--bg-dark);
            color: #ffffff;
            font-family: 'Terminal', monospace;
            overflow: hidden;
            display: flex;
        }

        /* --- BACKGROUND FX: FRUIT RAIN --- */
        #fruitCanvas {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1; pointer-events: none;
            opacity: 0.15;
        }

        /* --- SIDEBAR NAVIGATION --- */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: var(--bg-nav);
            border-right: 2px solid var(--primary);
            display: flex;
            flex-direction: column;
            z-index: 100;
            box-shadow: 10px 0 30px rgba(0,0,0,0.5);
        }

        .logo-area {
            padding: 40px 20px;
            text-align: center;
            border-bottom: 1px solid #1a5c41;
        }

        .logo-main {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--primary);
            letter-spacing: 4px;
            text-shadow: 0 0 10px var(--primary-glow);
        }

        .logo-sub {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-top: 5px;
        }

        .nav-links {
            flex-grow: 1;
            padding-top: 20px;
            display: flex;
            flex-direction: column;
        }

        .tab-btn {
            background: none;
            border: none;
            padding: 18px 25px;
            color: var(--text-dim);
            text-align: left;
            cursor: pointer;
            font-family: 'Terminal';
            font-size: 0.9rem;
            text-transform: uppercase;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .tab-btn:hover {
            color: #fff;
            background: rgba(0, 255, 102, 0.05);
        }

        .tab-btn.active {
            color: var(--primary);
            background: rgba(0, 255, 102, 0.15);
            border-left: 4px solid var(--primary);
            text-shadow: 0 0 5px var(--primary);
        }

        /* --- SYSTEM MONITOR (BOTTOM SIDEBAR) --- */
        .sys-mon {
            padding: 20px;
            background: rgba(0,0,0,0.3);
            border-top: 1px solid #1a5c41;
            font-size: 0.7rem;
        }

        .sys-item { display: flex; justify-content: space-between; margin-bottom: 5px; }
        .sys-label { color: var(--text-dim); }
        .sys-value { color: var(--primary); }

        /* --- MAIN CONTENT WINDOW --- */
        .content {
            flex-grow: 1;
            height: 100vh;
            overflow-y: auto;
            position: relative;
            background: radial-gradient(circle at center, rgba(0, 255, 102, 0.03) 0%, transparent 70%);
        }

        .tab-content {
            display: none;
            padding: 30px;
            height: calc(100vh - 60px);
            animation: bootUp 0.4s ease-out;
        }

        @keyframes bootUp {
            from { opacity: 0; transform: scale(0.98); filter: brightness(2); }
            to { opacity: 1; transform: scale(1); filter: brightness(1); }
        }

        .tab-content.active { display: block; }

        /* --- REUSABLE COMPONENTS --- */
        .frame-wrapper {
            width: 100%;
            height: 90%;
            border: 1px solid var(--primary);
            background: #000;
            box-shadow: 0 0 20px rgba(0,0,0,1);
            position: relative;
        }

        iframe { width: 100%; height: 100%; border: none; }

        .terminal-header {
            background: var(--primary);
            color: #000;
            padding: 5px 15px;
            font-size: 0.7rem;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
        }

        /* --- GAME VAULT GRID --- */
        .game-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .game-card {
            background: var(--panel);
            border: 1px solid #1a5c41;
            padding: 15px;
            transition: 0.3s;
            cursor: pointer;
        }

        .game-card:hover {
            border-color: var(--primary);
            transform: translateY(-5px);
            box-shadow: 0 5px 15px var(--primary-glow);
        }

        .game-title { color: var(--primary); font-size: 1.1rem; margin-bottom: 5px; }
        .game-desc { font-size: 0.75rem; color: #888; margin-bottom: 15px; }
        .launch-btn {
            background: var(--primary);
            color: #000;
            padding: 8px 15px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.8rem;
            display: inline-block;
        }

        /* --- PANIC BUTTON --- */
        .panic-bar {
            position: fixed; bottom: 20px; right: 20px;
            z-index: 1000;
        }

        .panic-btn {
            background: var(--danger);
            color: #fff;
            border: none;
            padding: 10px 20px;
            font-family: 'Terminal';
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(255,0,0,0.5);
        }

        /* --- CHAT OVERRIDE (NO AVATARS) --- */
        #minchat-embed { filter: grayscale(1) contrast(1.2) brightness(0.8); }

    </style>
</head>
<body>

    <canvas id="fruitCanvas"></canvas>

    <div class="sidebar">
        <div class="logo-area">
            <div class="logo-main">REMS CORNER</div>
            <div class="logo-sub">SECURE GAMING KERNEL v4.0.2</div>
        </div>

        <div class="nav-links">
            <button class="tab-btn active" onclick="openTab(event, 'chat')">>> GLOBAL_CHAT</button>
            <button class="tab-btn" onclick="openTab(event, 'games')">>> GAME_VAULT</button>
            <button class="tab-btn" onclick="openTab(event, 'mc')">>> MINECRAFT_HUB</button>
            <button class="tab-btn" onclick="openTab(event, 'srv')">>> SRV_OPERATOR</button>
            <button class="tab-btn" onclick="openTab(event, 'web')">>> WEB_PORTAL</button>
            <button class="tab-btn" onclick="openTab(event, 'gemini')">>> GEMINI_AI</button>
        </div>

        <div class="sys-mon">
            <div class="sys-item"><span class="sys-label">UPTIME:</span> <span class="sys-value" id="uptime">0s</span></div>
            <div class="sys-item"><span class="sys-label">CPU:</span> <span class="sys-value">02%</span></div>
            <div class="sys-item"><span class="sys-label">LOC:</span> <span class="sys-value">2026.03.20</span></div>
            <div class="sys-item"><span class="sys-label">USER:</span> <span class="sys-value">GUEST_REM</span></div>
        </div>
    </div>

    <div class="content">
        
        <div id="chat" class="tab-content active">
            <h2 style="color:var(--primary)">> CHANNEL: #GLOBAL_COMM</h2>
            <div class="frame-wrapper">
                <div class="terminal-header"><span>SECURE_TEXT_ONLY_STREAM</span><span>ENCRYPTED</span></div>
                <iframe src="https://minchat.io/chat/rems-corner"></iframe>
            </div>
        </div>

        <div id="games" class="tab-content">
            <h2 style="color:var(--primary)">> INDEX: /LOCAL/STORAGE/GAMES</h2>
            <div class="game-grid">
                <div class="game-card" onclick="window.open('https://brotato.io', '_blank')">
                    <div class="game-title">BROTATO</div>
                    <div class="game-desc">Arena survival shooter. 2026 Mirror.</div>
                    <span class="launch-btn">EXTERNAL_BOOT</span>
                </div>
                <div class="game-card" onclick="location.hash='mc'">
                    <div class="game-title">1v1.LOL</div>
                    <div class="game-desc">High-speed builder shooter. Verified.</div>
                    <span class="launch-btn" onclick="openTab(event, 'v1v1')">LOAD_IFRAME</span>
                </div>
                <div class="game-card">
                    <div class="game-title">ROBLOX</div>
                    <div class="game-desc">Now.gg Cloud Player. Bypasses Firewall.</div>
                    <a href="https://now.gg/apps/roblox-corporation/5349/roblox.html" target="_blank" class="launch-btn">CONNECT</a>
                </div>
                <div class="game-card">
                    <div class="game-title">BITLIFE</div>
                    <div class="game-desc">Life sim. Text-based logic.</div>
                    <a href="https://bitlifeonline.io" target="_blank" class="launch-btn">CONNECT</a>
                </div>
            </div>
        </div>

        <div id="mc" class="tab-content">
            <h2 style="color:var(--primary)">> MC_HUB: SELECT_VERSION</h2>
            <div style="margin-bottom:10px;">
                <button class="launch-btn" style="border:none; cursor:pointer;" onclick="loadMC('1.8')">BOOT 1.8.8</button>
                <button class="launch-btn" style="border:none; cursor:pointer; background:#fff;" onclick="loadMC('1.12')">BOOT 1.12.2</button>
            </div>
            <div class="frame-wrapper">
                <iframe id="mc-frame" src="https://svaaps.github.io/eaglercrafthtml/"></iframe>
            </div>
        </div>

        <div id="srv" class="tab-content">
            <h2 style="color:var(--primary)">> SRV_CTRL: INSTANCE_MANAGER</h2>
            <div style="background:var(--panel); border:1px solid var(--primary); padding:30px;">
                <p>INITIALIZE WEBRTC P2P SERVER TUNNEL</p>
                <input type="text" id="srv-name" placeholder="SERVER_ID..." style="background:#000; border:1px solid var(--primary); color:var(--primary); padding:10px; width:300px;">
                <button class="launch-btn" style="border:none; padding:12px 25px; margin-left:10px;" onclick="initSrv()">START_SEQUENCE</button>
                <div id="srv-log" style="margin-top:20px; font-size:0.8rem; color:var(--text-dim);"></div>
            </div>
        </div>

        <div id="web" class="tab-content">
            <h2 style="color:var(--primary)">> WEB_PROXY: EDUCATIONAL_GATEWAY</h2>
            <div class="frame-wrapper">
                <iframe src="https://education.mathematicsontop.it.com/"></iframe>
            </div>
        </div>

        <div id="gemini" class="tab-content">
            <h2 style="color:var(--primary)">> AI_LINK: GOOGLE_GEMINI</h2>
            <div class="frame-wrapper">
                <iframe src="https://gemini.google.com"></iframe>
            </div>
        </div>
    </div>

    <div class="panic-bar">
        <button class="panic-btn" onclick="panic()">EMERGENCY: ESC</button>
    </div>

    <script>
        // TAB CONTROLLER
        function openTab(evt, tabName) {
            let i, content, btns;
            content = document.getElementsByClassName("tab-content");
            for (i = 0; i < content.length; i++) content[i].style.display = "none";
            btns = document.getElementsByClassName("tab-btn");
            for (i = 0; i < btns.length; i++) btns[i].className = btns[i].className.replace(" active", "");
            document.getElementById(tabName).style.display = "block";
            evt.currentTarget.className += " active";
        }

        // MC LOADER
        function loadMC(ver) {
            const frame = document.getElementById('mc-frame');
            if(ver === '1.8') frame.src = "https://svaaps.github.io/eaglercrafthtml/";
            else frame.src = "https://raw.githack.com/ZixiaChen/Eaglercraft-1.12.2/main/Web/index.html";
        }

        // PANIC LOGIC
        function panic() { window.location.href = "https://classroom.google.com"; }
        document.addEventListener('keydown', (e) => { if(e.key === "Escape") panic(); });

        // UPTIME COUNTER
        let seconds = 0;
        setInterval(() => {
            seconds++;
            document.getElementById('uptime').innerText = seconds + "s";
        }, 1000);

        // SERVER SIMULATOR
        function initSrv() {
            const log = document.getElementById('srv-log');
            log.innerHTML += "<p>> Requesting Handshake...</p>";
            setTimeout(() => { log.innerHTML += "<p>> Tunnel Established via relay.lax1dude.net</p>"; }, 1000);
            setTimeout(() => { log.innerHTML += "<p style='color:#fff'>> SUCCESS: Server Online. Join Code: " + Math.floor(10000 + Math.random() * 90000) + "</p>"; }, 2500);
        }

        // FRUIT RAIN ENGINE v2
        const canvas = document.getElementById('fruitCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const fruits = ['🍎', '🍏', '🍇', '🍉', '🍓', '🍒', '🍍', '🥝', '🍋', '🍑'];
        const particles = [];

        class Fruit {
            constructor() {
                this.reset();
                this.y = Math.random() * canvas.height;
            }
            reset() {
                this.x = Math.random() * canvas.width;
                this.y = -50;
                this.size = Math.random() * 20 + 15;
                this.speed = Math.random() * 1.5 + 0.5;
                this.char = fruits[Math.floor(Math.random() * fruits.length)];
            }
            update() {
                this.y += this.speed;
                if (this.y > canvas.height) this.reset();
            }
            draw() {
                ctx.font = `${this.size}px Arial`;
                ctx.fillText(this.char, this.x, this.y);
            }
        }

        for (let i = 0; i < 40; i++) particles.push(new Fruit());

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(animate);
        }
        animate();

        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });

    </script>
</body>
</html>
