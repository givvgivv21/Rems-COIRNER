<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REMS CORNER | THE EMERALD HUB</title>
    <style>
        :root {
            --primary: #00ff66; /* Neon Lime */
            --dark-green: #023020; /* Deep Emerald */
            --bg: #011a12;
            --card-bg: rgba(2, 48, 32, 0.8);
            --text: #e0ffe0;
        }

        /* Flashy Animations */
        @keyframes glow {
            0% { text-shadow: 0 0 10px var(--primary); }
            50% { text-shadow: 0 0 30px #ffffff, 0 0 40px var(--primary); }
            100% { text-shadow: 0 0 10px var(--primary); }
        }

        body, html { 
            margin: 0; padding: 0; height: 100%; 
            font-family: 'Black Ops One', 'Segoe UI', sans-serif; 
            background: var(--bg); color: var(--text); 
            overflow: hidden; 
        }

        /* Fruit Rain Canvas */
        #fruitCanvas {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1; pointer-events: none;
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 240px; height: 100vh;
            background: rgba(1, 26, 18, 0.9);
            position: fixed; display: flex; flex-direction: column;
            border-right: 2px solid var(--primary);
            backdrop-filter: blur(10px);
            z-index: 100;
        }

        .logo { 
            padding: 30px 20px; font-size: 1.8rem; font-weight: 900; 
            color: var(--primary); text-align: center;
            animation: glow 2s infinite; letter-spacing: 3px;
        }

        .tab-btn {
            padding: 20px; cursor: pointer; border: none; background: none;
            color: #4a8c6f; text-align: left; font-size: 1.1rem;
            text-transform: uppercase; font-weight: bold; transition: 0.3s;
        }

        .tab-btn:hover { color: #fff; background: rgba(0, 255, 102, 0.1); }
        .tab-btn.active { color: var(--primary); background: rgba(0, 255, 102, 0.2); border-right: 5px solid var(--primary); }

        /* Main Content */
        .content { margin-left: 240px; height: 100vh; overflow-y: auto; position: relative; }
        .tab-content { display: none; padding: 40px; animation: fadeIn 0.5s ease; }
        .tab-content.active { display: block; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Game Grid - Massive Collection */
        .game-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 25px; }
        .game-card { 
            background: var(--card-bg); border-radius: 15px; overflow: hidden; 
            border: 1px solid #1a5c41; transition: 0.4s; position: relative;
        }
        .game-card:hover { 
            transform: scale(1.05) rotate(1deg); 
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(0, 255, 102, 0.4);
        }
        .game-card img { width: 100%; height: 140px; object-fit: cover; filter: grayscale(30%); }
        .game-card:hover img { filter: grayscale(0%); }
        .game-info { padding: 15px; text-align: center; }
        .play-btn { 
            display: block; background: var(--primary); color: #000; 
            text-decoration: none; padding: 10px; font-weight: bold; border-radius: 0 0 15px 15px;
        }

        /* Iframe Containers */
        .frame-container { width: 100%; height: 80vh; border: 3px solid var(--primary); border-radius: 20px; overflow: hidden; background: #000; }
        iframe { width: 100%; height: 100%; border: none; }

        h2 { font-size: 2.5rem; border-left: 10px solid var(--primary); padding-left: 15px; margin-bottom: 30px; }
    </style>
</head>
<body>

    <canvas id="fruitCanvas"></canvas>

    <div class="sidebar">
        <div class="logo">REMS<br>CORNER</div>
        <button class="tab-btn active" onclick="openTab(event, 'games')">🕹️ GAME VAULT</button>
        <button class="tab-btn" onclick="openTab(event, 'gemini')">🧠 GEMINI AI</button>
        <button class="tab-btn" onclick="openTab(event, 'browser')">🌍 UNBLOCKED WEB</button>
        <button class="tab-btn" onclick="openTab(event, 'youtube')">🎥 REMS TV</button>
    </div>

    <div class="content">
        <div id="games" class="tab-content active">
            <h2>POPULAR TITLES</h2>
            <div class="game-grid">
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1614850523296-d8c1af93d400?w=300" alt="Slope">
                    <div class="game-info"><h3>Slope</h3><p>Fast-paced 3D</p></div>
                    <a href="https://retro-bowl-26.github.io/slope/" class="play-btn">LAUNCH</a>
                </div>
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1566577739112-5180d4bf9390?w=300" alt="Retro Bowl">
                    <div class="game-info"><h3>Retro Bowl</h3><p>8-Bit Football</p></div>
                    <a href="https://retro-bowl-26.github.io/" class="play-btn">LAUNCH</a>
                </div>
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?w=300" alt="1v1">
                    <div class="game-info"><h3>1v1.LOL</h3><p>Build & Shoot</p></div>
                    <a href="https://1v1.lol" class="play-btn">LAUNCH</a>
                </div>
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1627398242454-45a1465c2479?w=300" alt="Minecraft">
                    <div class="game-info"><h3>Minecraft</h3><p>Classic Web</p></div>
                    <a href="https://classic.minecraft.net" class="play-btn">LAUNCH</a>
                </div>
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300" alt="Bitlife">
                    <div class="game-info"><h3>BitLife</h3><p>Life Simulator</p></div>
                    <a href="https://www.bitlifeonline.com/" class="play-btn">LAUNCH</a>
                </div>
                <div class="game-card">
                    <img src="https://images.unsplash.com/photo-1523049673857-eb18f1d7b578?w=300" alt="Snake">
                    <div class="game-info"><h3>Google Snake</h3><p>Retro Fun</p></div>
                    <a href="https://www.google.com/fbx?fbx=snake_arcade" class="play-btn">LAUNCH</a>
                </div>
            </div>
        </div>

        <div id="gemini" class="tab-content">
            <h2>GEMINI CLONE</h2>
            <div class="frame-container">
                <iframe src="https://gemini.google.com/app"></iframe>
            </div>
        </div>

        <div id="browser" class="tab-content">
            <h2>SECURE BROWSER</h2>
            <div class="frame-container">
                <iframe src="https://www.bing.com"></iframe>
            </div>
        </div>

        <div id="youtube" class="tab-content">
            <h2>YOUTUBE STREAM</h2>
            <div class="frame-container">
                <iframe src="https://www.youtube.com/embed/videoseries?list=PLWwAypHuER7jgE5t_eOqf_f7z7_p5Yw0h"></iframe>
            </div>
        </div>
    </div>

    <script>
        // Tab System
        function openTab(evt, tabName) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) { tabcontent[i].style.display = "none"; tabcontent[i].classList.remove("active"); }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) { tablinks[i].classList.remove("active"); }
            document.getElementById(tabName).style.display = "block";
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }

        // FRUIT RAIN ENGINE
        const canvas = document.getElementById('fruitCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const fruits = ['🍎', '🍏', '🍇', '🍉', '🍓', '🍒', '🍍', '🥝', '🍋', '🍑'];
        const particles = [];

        class Fruit {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = -50;
                this.size = Math.random() * 30 + 20;
                this.speed = Math.random() * 3 + 2;
                this.rot = Math.random() * 360;
                this.rotSpeed = Math.random() * 5 - 2.5;
                this.emoji = fruits[Math.floor(Math.random() * fruits.length)];
            }
            update() {
                this.y += this.speed;
                this.rot += this.rotSpeed;
                if (this.y > canvas.height) {
                    this.y = -50;
                    this.x = Math.random() * canvas.width;
                }
            }
            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.rot * Math.PI / 180);
                ctx.font = `${this.size}px Arial`;
                ctx.fillText(this.emoji, 0, 0);
                ctx.restore();
            }
        }

        for (let i = 0; i < 40; i++) { particles.push(new Fruit()); }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(animate);
        }
        animate();

        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });
    </script>

</body>
</html>
