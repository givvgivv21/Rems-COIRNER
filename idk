function unproxyBoot() {
    const rawUrl = document.getElementById('unproxy-url').value;
    if (!rawUrl) return alert("Enter URL");
    
    // Format URL instantly
    const targetUrl = rawUrl.startsWith('http') ? rawUrl : 'https://' + rawUrl;

    // STEP 1: Open the window IMMEDIATELY (This bypasses the pop-up blocker)
    const stealthWin = window.open('', '_blank');

    if (!stealthWin) {
        alert("POP-UP BLOCKED: Click the icon in your URL bar to 'Always Allow' pop-ups!");
        return;
    }

    // STEP 2: Inject the Stealth Masking directly into the new window
    try {
        stealthWin.document.write(`
            <title>Stealth Mode</title>
            <body style="background:#000;color:#f97316;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;font-family:sans-serif;">
                <div style="text-align:center;">
                    <div style="border:3px solid #333;border-top:3px solid #f97316;border-radius:50%;width:30px;height:30px;animation:spin 1s linear infinite;margin:0 auto 20px auto;"></div>
                    <h2 style="margin:0;letter-spacing:-1px;">UNPROXIER ACTIVE</h2>
                    <p style="font-size:10px;opacity:0.5;margin-top:10px;">HARDWARE MASKED | ORIGIN STRIPPED</p>
                </div>
                <style>@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }</style>
                <script>
                    // Apply Stealth Headers
                    Object.defineProperty(navigator, 'webdriver', {get: () => false});
                    Object.defineProperty(navigator, 'deviceMemory', {get: () => 8});
                    Object.defineProperty(navigator, 'hardwareConcurrency', {get: () => 4});
                    
                    // Kill the Referer by using location.replace
                    setTimeout(() => { window.location.replace("${targetUrl}"); }, 300);
                <\/script>
            </body>
        `);
    } catch (e) {
        // Fallback if document.write fails
        stealthWin.location.href = targetUrl;
    }
}
